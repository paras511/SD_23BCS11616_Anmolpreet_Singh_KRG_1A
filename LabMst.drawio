        <mxCell id="BNF0GBFyddUYrFXLH8pV-1" parent="1" style="whiteSpace=wrap;html=1;" value="Design an instagram like System with following requirements:-&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1-&amp;gt;User Service login.&lt;/span&gt;&lt;div&gt;2-&amp;gt;Content Service.&lt;/div&gt;&lt;div&gt;3-&amp;gt;Feed Service.&lt;/div&gt;&lt;div&gt;4-&amp;gt;Follower Service.&lt;/div&gt;&lt;div&gt;5-&amp;gt;User Engagement Service.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Implement a mechanism to restrict the user for posting a non-policy compliant post .&lt;/div&gt;&lt;div&gt;Optimize the dynamic feed generation for the users. Hightlight the use of back fill service.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="1030" x="130" y="70" as="geometry" />
        </mxCell>
        <mxCell id="BNF0GBFyddUYrFXLH8pV-2" parent="1" style="whiteSpace=wrap;html=1;" value="Functional Requirements:-&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1-&amp;gt; User should be able to login or signi in.&lt;/div&gt;&lt;div&gt;2-&amp;gt;Users should be able to follow each other.&lt;/div&gt;&lt;div&gt;3-&amp;gt;Continously refreshing the feed.&lt;/div&gt;&lt;div&gt;4-&amp;gt;Handle Likes,Dislikes and comments.&lt;/div&gt;&lt;div&gt;5-&amp;gt; push and pull feed (fanout, fanin)&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="440" x="121" y="280" as="geometry" />
        </mxCell>
        <mxCell id="BNF0GBFyddUYrFXLH8pV-3" parent="1" style="whiteSpace=wrap;html=1;" value="Non Functional Requirements:-&lt;div&gt;1-&amp;gt;Scalability.&lt;/div&gt;&lt;div&gt;2-&amp;gt;Availabilty.&lt;/div&gt;&lt;div&gt;3-&amp;gt;Daily active users 1M.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="450" x="720" y="280" as="geometry" />
